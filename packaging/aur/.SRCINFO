pkgbase = sony-head-tracker-git
	pkgdesc = Use Sony headphones as a head tracker for OpenTrack (Linux CLI + GTK app)
	pkgver = r1
	pkgrel = 1
	url = https://github.com/melcodesdev/sony-head-tracker-linux
	install = sony-head-tracker-git.install
	arch = x86_64
	license = MIT
	makedepends = git
	makedepends = gcc
	makedepends = make
	depends = gtk4
	depends = libadwaita
	depends = python-gobject
	depends = python
	depends = hicolor-icon-theme
	optdepends = opentrack: drive the in-game camera from the head-tracking data
	optdepends = bluez-utils: pair the headset from the terminal with bluetoothctl
	optdepends = p7zip: OpenTrack setup for Steam/Proton games
	optdepends = curl: download OpenTrack for Steam/Proton setup
	provides = sony-head-tracker
	conflicts = sony-head-tracker
	source = sony-head-tracker-git::git+https://github.com/melcodesdev/sony-head-tracker-linux.git#branch=linux-support
	sha256sums = SKIP

pkgname = sony-head-tracker-git
